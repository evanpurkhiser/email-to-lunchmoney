  },
  "dependencies": {
    "@sentry/cloudflare": "^9.36.0",
    "date-fns": "^4.1.0",
    "hono": "^4.11.5",
    "html-to-text": "^9.0.5",
    "openai": "^5.8.3",
    "pdfjs-serverless": "^1.1.0",
